{
    "name": "tavp/tavphub",
    "description": "TAVPhub — admin panel for TAVP (sidebar, dashboard, CRUD resources).",
    "type": "library",
    "license": "MIT",
    "keywords": ["tavp", "admin", "panel", "crud", "bread"],
    "require": {
        "php": ">=8.3",
        "tavp/core": "^1.1"
    },
    "require-dev": {
        "phpunit/phpunit": "^10.0"
    },
    "autoload": {
        "psr-4": {
            "Tavp\\Hub\\": "src/"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "Tavp\\Hub\\Tests\\": "tests/"
        }
    },
    "config": {
        "sort-packages": true,
        "allow-plugins": []
    },
    "support": {
        "issues": "https://github.com/tavp-stack/tavphub/issues",
        "source": "https://github.com/tavp-stack/tavphub"
    }
}
