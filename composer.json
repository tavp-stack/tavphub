{
    "name": "tavp/tavphub",
    "description": "TAVPhub — admin panel for TAVP (sidebar, dashboard, CRUD resources).",
    "type": "tavpkit-module",
    "license": "MIT",
    "require": { "php": ">=8.1" },
    "require-dev": { "phpunit/phpunit": "^10.0" },
